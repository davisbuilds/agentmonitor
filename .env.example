# Server
AGENTMONITOR_PORT=3141
AGENTMONITOR_HOST=127.0.0.1
AGENTMONITOR_DB_PATH=./data/agentmonitor.db
AGENTMONITOR_MAX_PAYLOAD_KB=10
AGENTMONITOR_SESSION_TIMEOUT=5
AGENTMONITOR_MAX_FEED=200
AGENTMONITOR_STATS_INTERVAL=5000
AGENTMONITOR_MAX_SSE_CLIENTS=50
AGENTMONITOR_SSE_HEARTBEAT_MS=30000
AGENTMONITOR_AUTO_IMPORT_MINUTES=10
AGENTMONITOR_PROJECTS_DIR=              # auto-detected from cwd ancestry; falls back to cwd

# Usage Monitor — base window (applies to all agents unless overridden)
AGENTMONITOR_SESSION_WINDOW_HOURS=5

# Usage Monitor — Claude Code (token limits)
AGENTMONITOR_SESSION_WINDOW_HOURS_CLAUDE_CODE=5
AGENTMONITOR_SESSION_TOKEN_LIMIT_CLAUDE_CODE=44000
AGENTMONITOR_EXTENDED_WINDOW_HOURS_CLAUDE_CODE=24
AGENTMONITOR_EXTENDED_TOKEN_LIMIT_CLAUDE_CODE=0
AGENTMONITOR_WEEKLY_WINDOW_HOURS_CLAUDE_CODE=168
AGENTMONITOR_WEEKLY_TOKEN_LIMIT_CLAUDE_CODE=293000

# Usage Monitor — Codex (cost limits in USD cents)
AGENTMONITOR_SESSION_WINDOW_HOURS_CODEX=5
AGENTMONITOR_SESSION_COST_LIMIT_CODEX=500
AGENTMONITOR_EXTENDED_WINDOW_HOURS_CODEX=168
AGENTMONITOR_EXTENDED_COST_LIMIT_CODEX=1500
