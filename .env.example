# Server
AGENTMONITOR_PORT=3141
AGENTMONITOR_HOST=127.0.0.1
# Defaults to <install-root>/data/agentmonitor.db. Leave unset unless you want a
# specific file: a relative path here is resolved against the working directory,
# so the DB you read depends on where you launched from.
# AGENTMONITOR_DB_PATH=/absolute/path/to/agentmonitor.db
AGENTMONITOR_MAX_PAYLOAD_KB=10
AGENTMONITOR_SESSION_TIMEOUT=5
AGENTMONITOR_MAX_FEED=200
AGENTMONITOR_STATS_INTERVAL=5000
AGENTMONITOR_MAX_SSE_CLIENTS=50
AGENTMONITOR_SSE_HEARTBEAT_MS=30000
AGENTMONITOR_AUTO_IMPORT_MINUTES=10
AGENTMONITOR_PROJECTS_DIR=              # auto-detected from cwd ancestry; falls back to cwd

# Live Tab / Live Capture
AGENTMONITOR_ENABLE_LIVE_TAB=true
AGENTMONITOR_CODEX_LIVE_MODE=otel-only # otel-only | exporter
AGENTMONITOR_LIVE_CAPTURE_PROMPTS=true
AGENTMONITOR_LIVE_CAPTURE_REASONING=true
AGENTMONITOR_LIVE_CAPTURE_TOOL_ARGUMENTS=true
AGENTMONITOR_LIVE_DIFF_PAYLOAD_MAX_BYTES=32768

# Native provider quota collection
AGENTMONITOR_CODEX_QUOTA_POLL_INTERVAL_MS=60000
